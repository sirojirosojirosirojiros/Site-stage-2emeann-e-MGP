{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}

<h1>Créer un compte</h1>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div style="
            background:#ffdddd;
            border:1px solid red;
            padding:10px;
            margin-bottom:15px;
            color:red;
        ">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{{ form_start(registrationForm) }}

    {{ form_row(registrationForm.email) }}

    {{ form_row(registrationForm.plainPassword, {
        label: 'Mot de passe'
    }) }}

    {{ form_row(registrationForm.agreeTerms) }}

    <button class="btn btn-primary" type="submit">
        S'inscrire
    </button>

{{ form_end(registrationForm) }}

<script>
document.addEventListener("DOMContentLoaded", function () {

    const passwordInput = document.querySelector('input[type="password"]');

    if (!passwordInput) return;

    const rules = {
        length: /.{8,}/,
        upper: /[A-Z]/,
        number: /[0-9]/,
        special: /[^A-Za-z0-9]/
    };

    const message = document.createElement("div");
    passwordInput.parentNode.appendChild(message);

    passwordInput.addEventListener("input", function () {

        const value = passwordInput.value;

        let errors = [];

        if (!rules.length.test(value))
            errors.push("8 caractères minimum");

        if (!rules.upper.test(value))
            errors.push("1 majuscule");

        if (!rules.number.test(value))
            errors.push("1 chiffre");

        if (!rules.special.test(value))
            errors.push("1 caractère spécial");

        if (errors.length === 0) {
            message.innerHTML = "Mot de passe valide";
            message.style.color = "green";
        } else {
            message.innerHTML = errors.join(", ");
            message.style.color = "red";
        }
    });
});
</script>

{% endblock %}